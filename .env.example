# ════════════════════════════════════════════════════════════════
#  Prism — Local Environment Overrides
# ════════════════════════════════════════════════════════════════
#  These values override secrets from Vault and vault/.env.
#  Only add variables you want to change for local development.
#
#  To use:  cp .env.example .env
#
#  Resolution order (first wins):
#    1. process.env (manual env vars)
#    2. This file (.env)
#    3. Vault service
#    4. Shared vault/.env fallback
# ════════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────
# PRISM_PORT="7777"

# ── Vault Connection ──────────────────────────────────────────
# Set these to connect to vault (or leave unset to use vault/.env)
# VAULT_URL="http://192.168.86.2:5599"
# VAULT_TOKEN=""

# ── Tools API ─────────────────────────────────────────────────
# TOOLS_API_URL="http://localhost:5590"

# ── MongoDB ───────────────────────────────────────────────────
# MONGO_URI="mongodb://user:password@localhost:27017/?directConnection=true&replicaSet=rs0&authSource=admin"
# PRISM_MONGO_DB_NAME="prism"

# ── MinIO ─────────────────────────────────────────────────────
# MINIO_ENDPOINT="http://localhost:9000"
# MINIO_ACCESS_KEY=""
# MINIO_SECRET_KEY=""
# PRISM_MINIO_BUCKET_NAME="prism"

# ── LM Studio ────────────────────────────────────────────────
# PROVIDER_LM_STUDIO_1_URL="http://localhost:1234"
# PROVIDER_LM_STUDIO_1_CONCURRENCY="1"

# ── AI Provider Keys (override if using your own keys) ────────
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# GOOGLE_API_KEY=""
