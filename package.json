{
  "name": "prism-service",
  "version": "1.0.0",
  "description": "Prism the AI Gateway — a centralized backend for routing requests to multiple AI providers",
  "type": "module",
  "main": "dist/boot.js",
  "scripts": {
    "start": "node dist/boot.js",
    "dev": "tsx watch src/boot.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:live": "vitest run --config vitest.live.config.ts",
    "test:lm-studio": "vitest run --config vitest.live.config.ts tests/live/lmStudioModels.live.test.js",
    "vram:bench": "node scripts/vram-bench.js",
    "vram:quick": "node scripts/vram-bench.js --skip-settings --contexts=4k,8k",
    "vram:model": "node scripts/vram-bench.js --skip-settings --contexts=4k",
    "consolidate": "node scripts/consolidate-memories.js",
    "consolidate:all": "node scripts/consolidate-memories.js --all",
    "consolidate:history": "node scripts/consolidate-memories.js --history",
    "consolidate:dry": "node scripts/consolidate-memories.js --dry-run",
    "deploy": "bash deploy.sh",
    "deploy:dry": "bash deploy.sh --dry-run"
  },
  "keywords": [
    "ai",
    "gateway",
    "openai",
    "anthropic",
    "google",
    "elevenlabs"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@google/genai": "^1.49.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@rodrigo-barraza/service-library": "github:rodrigo-barraza/service-library",
    "@rodrigo-barraza/utilities-library": "github:rodrigo-barraza/utilities-library",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "minio": "^8.0.7",
    "mongodb": "^7.2.0",
    "openai": "^6.37.0",
    "sharp": "^0.34.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^4.1.5"
  }
}
