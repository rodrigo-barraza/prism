{
  "name": "prism-service",
  "version": "1.0.0",
  "description": "Prism the AI Gateway — a centralized backend for routing requests to multiple AI providers",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/boot.js",
    "dev": "nodemon --legacy-watch src/boot.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "vitest run --config vitest.live.config.js",
    "test:lm-studio": "vitest run --config vitest.live.config.js tests/live/lmStudioModels.test.js",
    "vram:bench": "node scripts/vram-bench.js",
    "vram:quick": "node scripts/vram-bench.js --skip-settings --contexts=4k,8k",
    "vram:model": "node scripts/vram-bench.js --skip-settings --contexts=4k",
    "deploy": "bash deploy.sh",
    "deploy:dry": "bash deploy.sh --dry-run"
  },
  "keywords": [
    "ai",
    "gateway",
    "openai",
    "anthropic",
    "google",
    "elevenlabs"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@google/genai": "^1.49.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@rodrigo-barraza/utilities": "git+https://github.com/rodrigo-barraza/utilities-library.git",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "minio": "^8.0.7",
    "mongodb": "^7.1.0",
    "openai": "^6.34.0",
    "sharp": "^0.34.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  }
}
